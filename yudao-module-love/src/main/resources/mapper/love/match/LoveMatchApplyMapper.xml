<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.iocoder.yudao.module.love.dal.mysql.match.LoveMatchApplyMapper">

    <select id="selectDuplicateCount" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM love_match_apply
        WHERE deleted = b'0'
          AND from_user_id = #{fromUserId}
          AND to_user_id = #{toUserId}
    </select>

</mapper>
